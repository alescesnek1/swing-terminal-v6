# SwingWorker local worker configuration (TESTNET ONLY).
# Copy this file to .env.worker (which is gitignored) and fill in real values.
# These secrets live ONLY on your machine. They are never sent to the browser,
# never stored in Netlify, never written to the registry / Info.plist, and never
# placed in a swingworker:// URL.

# Worker hard gate. Must be exactly "testnet".
WORKER_MODE=testnet

# Netlify control server the worker reports to and polls for session/intent state.
BOT_CONTROL_URL=https://swing-terminal-v6.netlify.app

# Shared secret that authorizes the worker against the control server.
# Must match the BOT_WORKER_TOKEN environment variable configured in Netlify.
BOT_WORKER_TOKEN=replace_me

# Binance environment hard gate. Must be exactly "testnet".
BINANCE_ENV=testnet

# Binance Spot TESTNET API credentials (from https://testnet.binance.vision).
# NEVER put production/live keys here.
BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me

# Risk gate: maximum position size in USD. Must stay <= 10.
MAX_POSITION_USD=10

# How often the worker polls the control server (ms).
POLL_INTERVAL_MS=5000
